{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mde",
  "version": "0.1.0",
  "identifier": "com.mde.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1421",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "center": true,
        "visible": false,
        "transparent": false,
        "decorations": false,
        "devtools": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "dialog": null,
    "store": null,
    "opener": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.0-37",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "fileAssociations": [
      {
        "ext": ["md"],
        "name": "Markdown File",
        "description": "Markdown document"
      },
      {
        "ext": ["txt"],
        "name": "Text File",
        "description": "Plain text file"
      },
      {
        "ext": ["json"],
        "name": "JSON File",
        "description": "JSON data file"
      },
      {
        "ext": ["html"],
        "name": "HTML File",
        "description": "HTML document"
      }
    ]
  }
}
