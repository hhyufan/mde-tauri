# Use a MongoDB Atlas connection string when deploying to Vercel.
# Local example: mongodb://localhost:27017/mde
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mde?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
# PORT is only used for local `npm run start`; Vercel ignores it.
PORT=3200
